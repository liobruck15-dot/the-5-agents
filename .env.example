# ===== הגדרות סביבה — תבנית =====
# העתק קובץ זה ל-.env ומלא ערכים אמיתיים.
# אין להעלות את .env ל-Git (הוא כבר ב-.gitignore).

# מפתח ה-API של Anthropic (Claude) — חובה להפעלת הסוכנים
ANTHROPIC_API_KEY=

# המודל המוגדר כברירת מחדל לסוכנים
ANTHROPIC_MODEL=claude-opus-4-8

# מפתח OpenAI — ליצירת תמונות (סקיל gpt-image-gen, מודל gpt-image-2)
OPENAI_API_KEY=
